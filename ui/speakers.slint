import { Theme } from "theme.slint";

component PersonItem inherits Rectangle {
    in property <string> name;
    in property <string> role;
    in property <string> affiliation;
    in property <bool> primary: false;
    in property <bool> has-separator: false;

    background: Theme.palette.dark-deep-blue;
    border-radius: 4px;
    horizontal-stretch: 1;
    min-height: 40px;

    HorizontalLayout {
        padding: Theme.spaces.medium;
        spacing: Theme.spaces.medium;

        // Accent bar
        Rectangle {
            width: 3px;
            background: primary ? Theme.palette.lemon-green : Theme.palette.slint-blue;
            border-radius: 1px;
            horizontal-stretch: 0;
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;

            Text {
                text: name;
                color: Theme.palette.white;
                font-size: Theme.typo.description.size;
                font-weight: Theme.typo.description.weight;
            }
            Text {
                text: role;
                color: primary ? Theme.palette.lemon-green : Theme.palette.slint-blue;
                font-size: Theme.typo.label.size;
                font-weight: Theme.typo.label.weight;
            }
            Text {
                text: affiliation;
                color: Theme.palette.shark-gray;
                font-size: Theme.typo.label-light.size;
                font-weight: Theme.typo.label-light.weight;
            }
        }
    }

    if has-separator : Rectangle {
        width: parent.width - 2 * Theme.spaces.medium;
        height: 1px;
        x: Theme.spaces.medium;
        y: parent.height - self.height;
        background: Theme.palette.slint-blue;
        opacity: 0.15;
    }
}

component SectionTitle inherits Text {
    in property <string> label;

    text: label;
    color: Theme.palette.white;
    font-size: Theme.typo.header.size;
    font-weight: Theme.typo.header.weight;
}

export component SpeakersPanel inherits VerticalLayout {
    padding: Theme.spaces.large;
    spacing: Theme.spaces.medium;

    SectionTitle { label: "Workshop Committee"; }

    Text {
        text: "CHAIRS";
        color: Theme.palette.shark-gray;
        font-size: Theme.typo.label.size;
        font-weight: Theme.typo.label.weight;
        letter-spacing: 1.5px;
    }

    HorizontalLayout {
        spacing: Theme.spaces.medium;

        PersonItem {
            name: "Michael Alexander";
            role: "Chair";
            affiliation: "Austrian Academy of Sciences";
            primary: true;
        }
        PersonItem {
            name: "Anastassios Nanos";
            role: "Co-Chair";
            affiliation: "Nubificus Ltd.";
            primary: true;
        }
    }

    Text {
        text: "STEERING COMMITTEE";
        color: Theme.palette.shark-gray;
        font-size: Theme.typo.label.size;
        font-weight: Theme.typo.label.weight;
        letter-spacing: 1.5px;
    }

    HorizontalLayout {
        spacing: Theme.spaces.medium;

        PersonItem {
            name: "Michael Alexander";
            role: "Steering Committee";
            affiliation: "Austrian Academy of Sciences";
        }
        PersonItem {
            name: "Anastassios Nanos";
            role: "Steering Committee";
            affiliation: "Nubificus Ltd.";
        }
    }

    Text {
        text: "PROGRAM COMMITTEE";
        color: Theme.palette.shark-gray;
        font-size: Theme.typo.label.size;
        font-weight: Theme.typo.label.weight;
        letter-spacing: 1.5px;
    }

    Rectangle {
        background: Theme.palette.dark-deep-blue;
        border-radius: 4px;
        min-height: 40px;

        Text {
            text: "Program committee members will be announced soon.";
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description-light.weight;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
