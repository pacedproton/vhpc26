import { Theme } from "theme.slint";

component ScheduleEntry inherits Rectangle {
    in property <string> time;
    in property <string> title;
    in property <string> detail;
    in property <bool> is-break: false;
    in property <bool> is-keynote: false;
    in property <bool> has-separator: true;

    background: Theme.palette.dark-deep-blue;
    border-radius: 4px;
    min-height: 40px;

    HorizontalLayout {
        padding: Theme.spaces.medium;
        spacing: Theme.spaces.medium;

        // Accent bar
        Rectangle {
            width: 3px;
            background: is-break ? Theme.palette.shark-gray : is-keynote ? Theme.palette.lemon-green : Theme.palette.slint-blue;
            border-radius: 1px;
            horizontal-stretch: 0;
        }

        // Time
        Text {
            width: 42px;
            text: time;
            color: is-break ? Theme.palette.shark-gray : Theme.palette.white;
            font-size: Theme.typo.label.size;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-stretch: 0;
        }

        // Content
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;

            Text {
                text: title;
                color: is-break ? Theme.palette.shark-gray : Theme.palette.white;
                font-size: Theme.typo.description.size;
                font-weight: is-keynote ? 600 : Theme.typo.description.weight;
                wrap: word-wrap;
            }
            if detail != "" : Text {
                text: detail;
                color: Theme.palette.shark-gray;
                font-size: Theme.typo.label-light.size;
                font-weight: Theme.typo.label-light.weight;
                wrap: word-wrap;
            }
        }
    }

    if has-separator : Rectangle {
        width: parent.width - 2 * Theme.spaces.medium;
        height: 1px;
        x: Theme.spaces.medium;
        y: parent.height - self.height;
        background: Theme.palette.slint-blue;
        opacity: 0.15;
    }
}

export component SchedulePanel inherits VerticalLayout {
    padding: Theme.spaces.large;
    spacing: Theme.spaces.medium;

    Text {
        text: "Workshop Schedule";
        color: Theme.palette.white;
        font-size: Theme.typo.header.size;
        font-weight: Theme.typo.header.weight;
    }
    Text {
        text: "To be posted in June 2026";
        color: Theme.palette.shark-gray;
        font-size: Theme.typo.label.size;
        letter-spacing: 0.5px;
    }
}
