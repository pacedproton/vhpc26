import { Theme } from "theme.slint";

component ScheduleEntry inherits Rectangle {
    in property <string> time;
    in property <string> title;
    in property <string> detail;
    in property <bool> is-break: false;
    in property <bool> is-keynote: false;
    in property <bool> has-separator: true;

    background: Theme.palette.dark-deep-blue;
    border-radius: 4px;
    min-height: 40px;

    HorizontalLayout {
        padding: Theme.spaces.medium;
        spacing: Theme.spaces.medium;

        // Accent bar
        Rectangle {
            width: 2px;
            background: is-break ? Theme.palette.shark-gray : is-keynote ? Theme.palette.teal : Theme.palette.violet;
            border-radius: 1px;
            horizontal-stretch: 0;
        }

        // Time
        Text {
            width: 42px;
            text: time;
            color: is-break ? Theme.palette.shark-gray : Theme.palette.white;
            font-size: Theme.typo.label.size;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-stretch: 0;
        }

        // Content
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;

            Text {
                text: title;
                color: is-break ? Theme.palette.shark-gray : Theme.palette.white;
                font-size: Theme.typo.description.size;
                font-weight: is-keynote ? 600 : Theme.typo.description.weight;
                wrap: word-wrap;
            }
            if detail != "" : Text {
                text: detail;
                color: Theme.palette.shark-gray;
                font-size: Theme.typo.label-light.size;
                font-weight: Theme.typo.label-light.weight;
                wrap: word-wrap;
            }
        }
    }

    if has-separator : Rectangle {
        width: parent.width - 2 * Theme.spaces.medium;
        height: 1px;
        x: Theme.spaces.medium;
        y: parent.height - self.height;
        background: Theme.palette.violet;
        opacity: 0.15;
    }
}

export component SchedulePanel inherits VerticalLayout {
    padding: Theme.spaces.large;
    spacing: Theme.spaces.medium;

    Text {
        text: "Workshop Schedule";
        color: Theme.palette.white;
        font-size: Theme.typo.header.size;
        font-weight: Theme.typo.header.weight;
    }
    Text {
        text: "Preliminary Program — Times TBC";
        color: Theme.palette.shark-gray;
        font-size: Theme.typo.label.size;
        letter-spacing: 0.5px;
    }

    Rectangle { height: Theme.spaces.small; }

    ScheduleEntry { time: "09:00"; title: "Opening Remarks"; detail: "Michael Alexander & Anastassios Nanos"; is-keynote: true; }
    ScheduleEntry { time: "09:15"; title: "Keynote: GPU Memory Virtualization for LLM Training"; detail: "Speaker TBA"; is-keynote: true; }
    ScheduleEntry { time: "10:15"; title: "Coffee Break"; is-break: true; }
    ScheduleEntry { time: "10:45"; title: "Session 1 — Memory Management & Compression"; detail: "Paper presentations (3 × 25 min)"; }
    ScheduleEntry { time: "12:00"; title: "Lunch Break"; is-break: true; }
    ScheduleEntry { time: "13:30"; title: "Session 2 — Cloud-Native HPC & Virtualization"; detail: "Paper presentations (3 × 25 min)"; }
    ScheduleEntry { time: "15:00"; title: "Coffee Break"; is-break: true; }
    ScheduleEntry { time: "15:30"; title: "Session 3 — Panel Discussion & Open Problems"; detail: "Interactive session on future directions"; }
    ScheduleEntry { time: "16:30"; title: "Closing Remarks"; detail: ""; has-separator: false; }
}
