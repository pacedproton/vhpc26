import { Theme } from "theme.slint";
import { AppLinks } from "applinks.slint";

component DateRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <bool> has-separator: true;

    background: Theme.palette.dark-deep-blue;
    min-height: 36px;

    HorizontalLayout {
        padding-left: Theme.spaces.medium;
        padding-right: Theme.spaces.medium;
        padding-top: Theme.spaces.small;
        padding-bottom: Theme.spaces.small;

        Text {
            width: 120px;
            text: label;
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.label.size;
            font-weight: Theme.typo.label.weight;
            vertical-alignment: center;
        }
        Text {
            text: value;
            color: Theme.palette.white;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description.weight;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    if has-separator : Rectangle {
        width: parent.width - 2 * Theme.spaces.medium;
        height: 1px;
        x: Theme.spaces.medium;
        y: parent.height - self.height;
        background: Theme.palette.slint-blue;
        opacity: 0.15;
    }
}

component InfoBlock inherits Rectangle {
    in property <string> heading;

    background: Theme.palette.dark-deep-blue;
    border-radius: 4px;

    VerticalLayout {
        padding: Theme.spaces.medium;
        spacing: Theme.spaces.medium;

        Text {
            text: heading;
            color: Theme.palette.lemon-green;
            font-size: Theme.typo.header.size;
            font-weight: Theme.typo.header.weight;
        }

        @children
    }
}

export component SubmissionPanel inherits VerticalLayout {
    padding: Theme.spaces.large;
    spacing: Theme.spaces.medium;

    Text {
        text: "Dates & Submission";
        color: Theme.palette.white;
        font-size: Theme.typo.header.size;
        font-weight: Theme.typo.header.weight;
    }
    Text {
        text: "Submission deadline: May 26, 2026 (extended) · edas.info/newPaper.php?c=35100";
        color: Theme.palette.shark-gray;
        font-size: Theme.typo.label.size;
        font-weight: Theme.typo.label.weight;
        letter-spacing: 0.5px;
        wrap: word-wrap;
    }

    // Dates
    VerticalLayout {
        spacing: 0px;

        Text {
            text: "Important Dates";
            color: Theme.palette.lemon-green;
            font-size: Theme.typo.label.size;
            font-weight: Theme.typo.label.weight;
            letter-spacing: 0.5px;
        }

        Rectangle { height: Theme.spaces.small; }

        Rectangle {
            border-radius: 4px;
            background: Theme.palette.dark-deep-blue;
            clip: true;

            VerticalLayout {
                DateRow { label: "Submission"; value: "May 26, 2026  23:59 (extendeD) AoE  (rolling abstract)"; }
                DateRow { label: "Notification"; value: "June 12, 2026"; }
                DateRow { label: "Camera-Ready"; value: "July 10, 2026"; }
                DateRow { label: "Workshop"; value: "August 24–25, 2026 · Pisa, Italy"; has-separator: false; }
            }
        }
    }

    InfoBlock {
        heading: "Who Should Submit";

        Text {
            text: "VHPC targets systems researchers, virtualization engineers, and OS/runtime experts addressing AI+HPC convergence. Approximately 20 submissions expected; 6 papers accepted for presentation (competitive single-blind peer review).";
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description.weight;
            wrap: word-wrap;
        }
    }

    // Guidelines
    InfoBlock {
        heading: "Submission Guidelines";

        Text {
            text: "Papers should be formatted in Springer LNCS style and submitted as PDF. Full papers: up to 12 pages. Short / work-in-progress: up to 6 pages.";
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description.weight;
            wrap: word-wrap;
        }

        Rectangle {
            height: 1px;
            background: Theme.palette.slint-blue;
            opacity: 0.15;
        }

        Rectangle {
            background: #0025ff18;
            border-radius: 2px;

            HorizontalLayout {
                padding-top: 8px;
                padding-bottom: 8px;
                padding-left: Theme.spaces.medium;
                padding-right: Theme.spaces.medium;

                Text {
                    text: "↗  edas.info/newPaper.php?c=35100";
                    color: Theme.palette.slint-blue;
                    font-size: Theme.typo.description.size;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    wrap: word-wrap;
                    vertical-alignment: center;
                }
            }

            TouchArea {
                clicked => { AppLinks.open-url("https://edas.info/newPaper.php?c=35100"); }
            }
        }
    }

    // Proceedings
    Rectangle {
        background: Theme.palette.dark-deep-blue;
        border-radius: 4px;

        HorizontalLayout {
            padding: Theme.spaces.medium;
            spacing: Theme.spaces.medium;

            Rectangle {
                width: 3px;
                background: Theme.palette.lemon-green;
                border-radius: 1px;
                horizontal-stretch: 0;
            }

            VerticalLayout {
                spacing: Theme.spaces.small;
                horizontal-stretch: 1;

                Text {
                    text: "Proceedings";
                    color: Theme.palette.lemon-green;
                    font-size: Theme.typo.header.size;
                    font-weight: Theme.typo.header.weight;
                }
                Text {
                    text: "Accepted papers will be published in the Euro-Par Workshops proceedings by Springer in the LNCS series.";
                    color: Theme.palette.shark-gray;
                    font-size: Theme.typo.description.size;
                    font-weight: Theme.typo.description.weight;
                    wrap: word-wrap;
                }
            }
        }
    }
}
