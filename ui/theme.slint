// VHPC 2026 Dashboard Theme — Energy Monitor style

struct Font {
    size: length,
    weight: float,
}

export struct Typo {
    label: Font,
    label-light: Font,
    header: Font,
    header-item: Font,
    header-item-light: Font,
    value: Font,
    description: Font,
    description-light: Font,
    value-big: Font,
}
export struct Palette {
    pure-black: brush,
    dark-deep-blue: brush,
    shark-gray: brush,
    white: brush,
    
    // primary
    slint-blue: brush,
    lemon-green: brush,
    dimmer: brush,

    // accents mapped to old names to avoid breaking all panels at once
    teal: brush,
    violet: brush,

    // gradients
    lemon-green-gradient: brush,
    slint-blue-gradient: brush,
    dark-left-gradient: brush,
    bar-gradient: brush,
    alternative-bar-gradient: brush,
    tab-gradient: brush,
    background-gradient: brush,
}

export struct Spaces {
    small: length,
    medium: length,
    large: length,
}

export struct Durations {
    fast: duration,
    medium: duration,
    slow: duration,
}

export global Theme {
    in property <Palette> palette: {
        pure-black: #010d1f,
        dark-deep-blue: #071428,
        shark-gray: #3a4060,
        white: #FFFFFF,

        slint-blue: #0025FF,
        lemon-green: #DEFB3A,
        dimmer: #0000007b,

        // mapped
        teal: #DEFB3A,
        violet: #0025FF,

        lemon-green-gradient: @linear-gradient(135deg, #defb3a75 0%, #defb3a00 100%),
        slint-blue-gradient: @linear-gradient(135deg, #6c4bff76 0%, #6C4BFF00 100%),
        dark-left-gradient: @linear-gradient(90deg, #010d1f 0%, #010d1f85 50%, #010d1f00 100%),
        bar-gradient: @linear-gradient(180deg, #6C4BFF 0%, #6c4bff00 100%),
        alternative-bar-gradient: @linear-gradient(180deg, #CBE600 0%, #CBE60000 100%),
        tab-gradient: @linear-gradient(180deg, #0026ff21 0%, #0026ff01 100%),
        background-gradient: @radial-gradient(circle, #0026ff40 50%, #0025FF00 100%),
    };

    in property <Spaces> spaces: {
        small: 5px,
        medium: 12px,
        large: 24px,
    };

    in property <Durations> durations: {
        fast: 125ms,
        medium: 200ms,
        slow: 500ms,
    };

    in property <Typo> typo: {
        label: { size: 12px, weight: 500 },
        label-light: { size: 12px, weight: 400 },
        header: { size: 16px, weight: 600 },
        header-item: { size: 18px, weight: 400 },
        header-item-light: { size: 18px, weight: 200 },
        value: { size: 26px, weight: 500 },
        description: { size: 14px, weight: 400 },
        description-light: { size: 14px, weight: 200 },
        value-big: { size: 40px, weight: 200 },
    };
}
