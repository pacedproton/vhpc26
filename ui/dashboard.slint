import { Theme } from "theme.slint";
import { AppLinks } from "applinks.slint";

// Energy Monitor style ValueDisplay — accent bar + gradient bg + title/value/unit
component ValueCard inherits Rectangle {
    in property <string> title;
    in property <string> value;
    in property <string> unit;
    in property <bool> alt-colors: false;

    horizontal-stretch: 1;
    min-height: 70px;
    border-radius: 2px;
    background: alt-colors ? Theme.palette.slint-blue-gradient : Theme.palette.lemon-green-gradient;

    HorizontalLayout {
        padding-left: 15px;
        padding-right: 15px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 15px;

        // Accent bar
        Rectangle {
            width: 3px; // slightly thicker bar
            background: alt-colors ? Theme.palette.slint-blue : Theme.palette.lemon-green;
            horizontal-stretch: 0;
            border-radius: 1px;
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;

            Text {
                text: title;
                color: alt-colors ? Theme.palette.slint-blue : Theme.palette.lemon-green;
                font-size: Theme.typo.label.size;
                font-weight: Theme.typo.label.weight;
            }

            HorizontalLayout {
                alignment: start;
                spacing: 5px;

                Text {
                    text: value;
                    color: Theme.palette.white;
                    font-size: Theme.typo.value.size;
                    font-weight: Theme.typo.value.weight;
                    vertical-alignment: center;
                }

                Text {
                    text: unit;
                    color: alt-colors ? Theme.palette.slint-blue : Theme.palette.lemon-green;
                    font-size: Theme.typo.label-light.size;
                    font-weight: Theme.typo.label-light.weight;
                    vertical-alignment: bottom;
                    padding-bottom: 4px;
                }
            }
        }
    }
}

// Energy Monitor style GroupBox
component GroupBox inherits VerticalLayout {
    in property <string> title;

    spacing: Theme.spaces.medium;

    Text {
        text: title;
        color: Theme.palette.white;
        font-size: Theme.typo.header.size;
        font-weight: Theme.typo.header.weight;
        horizontal-alignment: left;
    }

    HorizontalLayout {
        spacing: Theme.spaces.medium;
        @children
    }
}

// Item with dark bg like Energy Monitor
component InfoItem inherits Rectangle {
    in property <bool> has-separator: false;

    background: Theme.palette.dark-deep-blue;
    border-radius: 2px;
    border-width: 1px;
    border-color: #ffffff0a;

    VerticalLayout {
        padding: Theme.spaces.medium;
        spacing: Theme.spaces.medium;

        @children
    }

    if has-separator : Rectangle {
        width: parent.width - 2 * Theme.spaces.medium;
        height: 1px;
        x: Theme.spaces.medium;
        y: parent.height - self.height;
        background: Theme.palette.slint-blue;
        opacity: 0.25;
    }
}

export component DashboardPanel inherits VerticalLayout {
    padding: Theme.spaces.large;
    spacing: 12px;

    // Title area
    VerticalLayout {
        spacing: 2px;

        Text {
            text: "21st Workshop on Virtualization, Containers, and";
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.header-item.size;
            font-weight: Theme.typo.header-item-light.weight;
        }
        Text {
            text: "Resource Isolation for Supercomputer AI";
            color: Theme.palette.white;
            font-size: Theme.typo.header-item.size;
            font-weight: Theme.typo.header-item.weight;
        }
        Rectangle { height: 4px; }
        Text {
            text: "21st Edition  ·  Co-located with Euro-Par 2026  ·  vhpc.org";
            color: Theme.palette.lemon-green;
            font-size: Theme.typo.label.size;
            font-weight: Theme.typo.label.weight;
            letter-spacing: 0.5px;
        }
    }

    // Prominent Call for Papers feature card (top-of-fold)
    Rectangle {
        background: Theme.palette.lemon-green-gradient;
        border-radius: 2px;
        min-height: 96px;
        border-width: 1px;
        border-color: #ffffff10;

        HorizontalLayout {
            padding-left: 18px;
            padding-right: 18px;
            padding-top: 14px;
            padding-bottom: 14px;
            spacing: 18px;

            // Accent bar
            Rectangle {
                width: 4px;
                background: Theme.palette.lemon-green;
                horizontal-stretch: 0;
                border-radius: 2px;
            }

            VerticalLayout {
                alignment: center;
                horizontal-stretch: 1;
                spacing: 6px;

                Text {
                    text: "CALL FOR PAPERS";
                    color: Theme.palette.lemon-green;
                    font-size: Theme.typo.label.size;
                    font-weight: Theme.typo.label.weight;
                    letter-spacing: 2px;
                }

                Text {
                    text: "Read the full CfP for VHPC '26";
                    color: Theme.palette.white;
                    font-size: Theme.typo.value.size;
                    font-weight: Theme.typo.value.weight;
                    wrap: word-wrap;
                }

                Text {
                    text: "Submission deadline May 26, 2026 · 23:59 AoE (extended)";
                    color: Theme.palette.shark-gray;
                    font-size: Theme.typo.description.size;
                    font-weight: Theme.typo.description.weight;
                    wrap: word-wrap;
                }
            }

            // Right-side action affordance
            VerticalLayout {
                alignment: center;
                horizontal-stretch: 0;

                Rectangle {
                    background: #00000040;
                    border-radius: 2px;
                    border-width: 1px;
                    border-color: Theme.palette.lemon-green;

                    HorizontalLayout {
                        padding-top: 8px;
                        padding-bottom: 8px;
                        padding-left: 14px;
                        padding-right: 14px;

                        Text {
                            text: "↗  Open CfP";
                            color: Theme.palette.lemon-green;
                            font-size: Theme.typo.label.size;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        TouchArea {
            clicked => { AppLinks.open-url("cfp/cfp.text"); }
        }
    }

    // Stats — ValueDisplay style
    GroupBox {
        title: "At a Glance";

        ValueCard {
            title: "Edition";
            value: "21st";
            unit: "year";
        }
        ValueCard {
            title: "Focus";
            value: "AI";
            unit: "+ HPC";
            alt-colors: true;
        }
        ValueCard {
            title: "Venue";
            value: "Pisa";
            unit: "Italy";
        }
    }

    // About — Item style
    InfoItem {
        Text {
            text: "About VHPC '26";
            color: Theme.palette.white;
            font-size: Theme.typo.header.size;
            font-weight: Theme.typo.header.weight;
        }

        Text {
            text: "This year, we highlight containers and virtualization as enabling substrates for scaled large language models, memory-intensive LLM training, and increasingly agentic AI systems that dynamically orchestrate tools, services, and distributed resources across cloud and HPC infrastructures.";
            color: Theme.palette.white;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description.weight;
            wrap: word-wrap;
        }

        Text {
            text: "The Workshop on Virtualization, Containers, and Resource Isolation for Supercomputer AI (VHPC) aims to bring together researchers and industrial practitioners facing the challenges posed by virtualization and containerization in AI-driven HPC and cloud infrastructures, in order to foster discussion, collaboration, mutual exchange of knowledge and experience, enabling research to ultimately provide novel solutions for virtualized computing systems of tomorrow.";
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description.weight;
            wrap: word-wrap;
        }

        Text {
            text: "Virtualization and container technologies constitute the programmable substrate of modern AI and HPC infrastructures. In the current AI era — characterized by large-scale model training, distributed inference, multimodal pipelines, and increasingly agentic systems — controlled and efficient execution across heterogeneous resources is essential. HPC centers and cloud operators must manage infrastructures composed of CPUs, GPUs, NPUs, high-performance interconnects, and emerging accelerators, while supporting highly dynamic and resource-intensive AI workloads.";
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description.weight;
            wrap: word-wrap;
        }

        Text {
            text: "Beyond resource isolation, controlled execution is a first-class concern. Deterministic execution models, state snapshotting, replay mechanisms, and execution tracing are increasingly relevant for debugging distributed AI systems, ensuring reproducibility of training runs, and governing agentic behavior across heterogeneous infrastructure.";
            color: Theme.palette.shark-gray;
            font-size: Theme.typo.description.size;
            font-weight: Theme.typo.description.weight;
            wrap: word-wrap;
        }

        Rectangle {
            height: 1px;
            background: Theme.palette.slint-blue;
            opacity: 0.25;
        }

        HorizontalLayout {
            spacing: Theme.spaces.large;

            VerticalLayout {
                spacing: 2px;
                horizontal-stretch: 1;
                Text {
                    text: "Michael Alexander";
                    color: Theme.palette.white;
                    font-size: Theme.typo.description.size;
                    font-weight: Theme.typo.description.weight;
                }
                Text {
                    text: "Chair · Austrian Academy of Sciences";
                    color: Theme.palette.lemon-green;
                    font-size: Theme.typo.label.size;
                    font-weight: Theme.typo.label.weight;
                }
            }

            VerticalLayout {
                spacing: 2px;
                horizontal-stretch: 1;
                Text {
                    text: "Anastassios Nanos";
                    color: Theme.palette.white;
                    font-size: Theme.typo.description.size;
                    font-weight: Theme.typo.description.weight;
                }
                Text {
                    text: "Co-Chair · Nubificus Ltd.";
                    color: Theme.palette.lemon-green;
                    font-size: Theme.typo.label.size;
                    font-weight: Theme.typo.label.weight;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.palette.slint-blue;
            opacity: 0.15;
        }

        // Social links row
        HorizontalLayout {
            spacing: Theme.spaces.medium;

            Rectangle {
                background: #0025ff18;
                border-radius: 2px;
                horizontal-stretch: 1;

                HorizontalLayout {
                    padding-top: 7px;
                    padding-bottom: 7px;
                    padding-left: Theme.spaces.medium;
                    padding-right: Theme.spaces.medium;

                    Text {
                        text: "↗  Bluesky: @vhpc.bsky.social";
                        color: Theme.palette.slint-blue;
                        font-size: Theme.typo.label.size;
                        font-weight: 600;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                TouchArea {
                    clicked => { AppLinks.open-url("https://bsky.app/profile/vhpc.bsky.social"); }
                }
            }

            Rectangle {
                background: #0025ff18;
                border-radius: 2px;
                horizontal-stretch: 1;

                HorizontalLayout {
                    padding-top: 7px;
                    padding-bottom: 7px;
                    padding-left: Theme.spaces.medium;
                    padding-right: Theme.spaces.medium;

                    Text {
                        text: "↗  X: @VHPCworkshop";
                        color: Theme.palette.slint-blue;
                        font-size: Theme.typo.label.size;
                        font-weight: 600;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                TouchArea {
                    clicked => { AppLinks.open-url("https://x.com/VHPCworkshop"); }
                }
            }
        }
    }
}
