import { Theme } from "theme.slint";

import { Theme } from "theme.slint";

component TabItem inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();

    min-width: 95px;
    background: active ? Theme.palette.tab-gradient : transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    VerticalLayout {
        // Top active accent bar (Energy Monitor style)
        Rectangle {
            height: 2px;
            background: active ? Theme.palette.lemon-green : transparent;
            
            animate background { duration: Theme.durations.fast; }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;

            Text {
                text: label;
                color: active ? Theme.palette.lemon-green : Theme.palette.white;
                font-size: Theme.typo.header-item.size;
                font-weight: active ? Theme.typo.header-item.weight : Theme.typo.header-item-light.weight;
                horizontal-alignment: center;
                vertical-alignment: center;

                animate color { duration: Theme.durations.fast; }
            }
        }
    }
}

// We keep the name "Sidebar" to avoid breaking main.slint immediately,
// but structurally this is now a horizontal Header block.
export component Sidebar inherits Rectangle {
    in property <int> active-index: 0;
    callback navigate(int);

    height: 70px;
    background: transparent;

    // Bottom edge line
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: #ffffff15; // faint line
    }

    HorizontalLayout {
        padding-left: Theme.spaces.large;
        padding-right: Theme.spaces.large;

        // Logo section (Left)
        HorizontalLayout {
            alignment: start;
            vertical-stretch: 1;
            spacing: Theme.spaces.medium;

            VerticalLayout {
                alignment: center;

                Text {
                    text: "VHPC";
                    color: Theme.palette.lemon-green;
                    font-size: Theme.typo.value.size;
                    font-weight: Theme.typo.value.weight;
                    letter-spacing: 2px;
                }
                Text {
                    text: "2026 // WORKSHOP";
                    color: Theme.palette.shark-gray;
                    font-size: 8px;
                    font-weight: Theme.typo.label.weight;
                    letter-spacing: 3px;
                }
            }
        }

        // Spacer
        Rectangle { horizontal-stretch: 1; }

        // Tabs section (Right)
        HorizontalLayout {
            alignment: end;
            spacing: 0px;

            TabItem {
                label: "Overview";
                active: active-index == 0;
                clicked => { root.navigate(0); }
            }
            TabItem {
                label: "Schedule";
                active: active-index == 1;
                clicked => { root.navigate(1); }
            }
            TabItem {
                label: "Topics";
                active: active-index == 2;
                clicked => { root.navigate(2); }
            }
            TabItem {
                label: "TPC";
                active: active-index == 3;
                clicked => { root.navigate(3); }
            }
            TabItem {
                label: "Dates & Sub.";
                active: active-index == 4;
                clicked => { root.navigate(4); }
            }
            TabItem {
                label: "Publication";
                active: active-index == 5;
                clicked => { root.navigate(5); }
            }
            TabItem {
                label: "Papers";
                active: active-index == 6;
                clicked => { root.navigate(6); }
            }
        }
    }
}
